{
  "name": "lobo-infinity-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run api:init-order && npm run security:cache && npm run security:armies && npm run test:achievements && npm run test:draws && npm run test:standings-integrity && npm run test:dashboard-api && npm run test:commissioner-submit && npm run test:commissioner-context && tsc -b && vite build",
    "release:source": "node scripts/release-source-check.mjs",
    "release:manifest": "node scripts/release-manifest-check.mjs",
    "release:fingerprint": "node scripts/generate-release-fingerprint.mjs",
    "release:contract": "node scripts/production-contract-check.mjs",
    "release:visual": "node scripts/production-visual-check.mjs",
    "release:promotion": "node scripts/release-promotion-check.mjs",
    "release:rollback-plan": "node scripts/rollback-plan.mjs",
    "release:safeguards:self-test": "node scripts/release-safeguard-self-test.mjs",
    "release:apps-script:syntax": "node scripts/apps-script-syntax-check.mjs",
    "release:gate": "npm run release:source && npm run release:manifest && npm run release:fingerprint && npm run build && npm run test:player-identity && npm run test:player-registry && npm run test:submit-game && npm run test:team-membership && npm run test:standings-integrity && npm run test:achievements && npm run test:commissioner-context && npm run release:apps-script:syntax && npm run release:contract",
    "analyze": "npm run build && node scripts/bundle-report.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "responsive:check": "node scripts/responsive-regression.mjs",
    "api:init-order": "node scripts/api-init-order-check.mjs",
    "league:navigation": "node scripts/league-navigation-check.mjs",
    "team-tournament:routing": "node scripts/team-tournament-routing-check.mjs",
    "test:commissioner-submit": "node scripts/commissioner-submit-check.mjs",
    "test:commissioner-context": "node scripts/commissioner-context-check.mjs",
    "test:submit-game": "node --experimental-strip-types scripts/submit-game-identity-check.ts",
    "test:team-membership": "node scripts/team-membership-check.mjs",
    "test:notifications": "node --experimental-strip-types scripts/notification-timestamp-check.ts",
    "test:achievements": "node scripts/achievement-rules-check.mjs",
    "test:battle-report": "node scripts/battle-report-check.mjs",
    "test:dashboard-links": "node scripts/dashboard-links-check.mjs",
    "test:dashboard-api": "node scripts/dashboard-api-contract-check.mjs",
    "test:draws": "node scripts/draw-support-check.mjs",
    "test:standings-integrity": "node scripts/standings-integrity-check.mjs",
    "test:player-profile": "node scripts/player-profile-check.mjs",
    "test:player-registry": "node scripts/player-registry-context-check.mjs",
    "test:player-identity": "node scripts/player-identity-check.mjs",
    "rules:check": "node scripts/firestore-rules-check.mjs",
    "security:cache": "node scripts/security-cache-audit.mjs",
    "security:armies": "node scripts/army-registry-audit.mjs"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
