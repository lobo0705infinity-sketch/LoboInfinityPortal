{
  "name": "lobo-infinity-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run security:cache && npm run security:armies && npm run test:achievements && tsc -b && vite build",
    "analyze": "npm run build && node scripts/bundle-report.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "responsive:check": "node scripts/responsive-regression.mjs",
    "league:navigation": "node scripts/league-navigation-check.mjs",
    "team-tournament:routing": "node scripts/team-tournament-routing-check.mjs",
    "test:submit-game": "node --experimental-strip-types scripts/submit-game-identity-check.ts",
    "test:notifications": "node --experimental-strip-types scripts/notification-timestamp-check.ts",
    "test:achievements": "node scripts/achievement-rules-check.mjs",
    "test:player-profile": "node scripts/player-profile-check.mjs",
    "test:player-registry": "node scripts/player-registry-context-check.mjs",
    "test:player-identity": "node scripts/player-identity-check.mjs",
    "rules:check": "node scripts/firestore-rules-check.mjs",
    "security:cache": "node scripts/security-cache-audit.mjs",
    "security:armies": "node scripts/army-registry-audit.mjs"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
